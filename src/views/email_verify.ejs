<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Email Verification</title>
</head>
<body>
    <!-- Preview text -->
    <span class="preheader" style="
        display: none !important;
        visibility: hidden;
        opacity: 0;
        color: transparent;
        height: 0;
        width: 0;
        border-collapse: collapse;
        border: 0px;
    "></span>

    <!-- Main container -->
    <table align="center" border="0" cellspacing="0" cellpadding="0">
        <tbody>
            <!-- Top spacer -->
            <tr>
                <td class="sectionlike imageless_section"></td>
            </tr>

            <!-- Verification content -->
            <tr>
                <td class="section">
                    <table border="0" cellspacing="0" cellpadding="0" class="section_content">
                        <tbody>
                            <tr>
                                <td class="section_content_padded">
                                    <h1>Hi <%= user.name %>,</h1>
                                    <p class="near_title last">
                                        Please verify that your email address is <%= user.email %>,
                                        that you entered it to sign up for <%= organisationData.organisation %>.
                                    </p>
                                    <a href="<%= url %>" class="button" target="_blank">
                                        Verify email
                                    </a>
                                    <small>
                                        Your email address stays private.
                                    </small>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>

            <!-- Signature -->
            <tr>
                <td class="section">
                    <table border="0" cellspacing="0" cellpadding="0" class="section_content section_zag">
                        <tbody>
                            <tr>
                                <td class="signature">
                                    <p class="marginless">
                                        Enjoy reading, <br/>
                                        The <%= organisationData.organisation %> Team
                                    </p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>

            <!-- Footer spacer -->
            <tr>
                <td class="section dummy_row"></td>
            </tr>

            <!-- Legal footer -->
            <tr>
                <td>
                    <table border="0" cellspacing="0" cellpadding="0" class="section_content">
                        <tbody>
                            <tr>
                                <td>
                                    <p class="footer_legal">
                                        If you did not enter this email address to sign up for
                                        <%= organisationData.organisation %> service, disregard this message.<br/><br/>
                                        © <%= organisationData.year %> <%= organisationData.organisation %>, 
                                        <%= organisationData.address %> <%= organisationData.organisationContact %><br/><br/>
                                        This is a mandatory service email from <%= organisationData.organisation %>.
                                    </p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>
</body>
</html>
